{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    // Disabled: the autogenerated Dataverse clients (src/generated/, "do not edit") build request
    // objects with explicit `undefined` on optional props, which exactOptionalPropertyTypes rejects.
    // They're imported as runtime values so `exclude` can't skip them. All other strict flags stay on;
    // app code still clears optional props by omitting the key (just no longer compiler-enforced).
    "exactOptionalPropertyTypes": false,
    "verbatimModuleSyntax": true,

    "types": ["vitest/globals", "@testing-library/jest-dom"]
  },
  "include": ["src"]
}
